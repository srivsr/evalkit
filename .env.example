# EvalKit v2 — Environment Variables
# Copy to .env and fill in your values

# Judge API Keys (at least one required)
EVALKIT_OPENAI_API_KEY=
EVALKIT_ANTHROPIC_API_KEY=

# Database
EVALKIT_DB_PATH=./evalkit.db

# Judge defaults
EVALKIT_DEFAULT_JUDGE=gpt-4o
EVALKIT_JUDGE_TIMEOUT_MS=30000
EVALKIT_JUDGE_MAX_TOKENS=2048
# EVALKIT_COST_CAP_USD=10.00

# Auth (Clerk)
EVALKIT_CLERK_SECRET_KEY=
EVALKIT_CLERK_PUBLISHABLE_KEY=
EVALKIT_ENVIRONMENT=production

# Payment — PayPal
EVALKIT_PAYPAL_CLIENT_ID=
EVALKIT_PAYPAL_CLIENT_SECRET=
EVALKIT_PAYPAL_MODE=live
EVALKIT_PAYPAL_WEBHOOK_ID=

# Payment — Razorpay
EVALKIT_RAZORPAY_KEY_ID=
EVALKIT_RAZORPAY_KEY_SECRET=
EVALKIT_RAZORPAY_WEBHOOK_SECRET=

# Payment — Payoneer
EVALKIT_PAYONEER_PARTNER_ID=
EVALKIT_PAYONEER_API_KEY=

# Rate Limiting
EVALKIT_RATE_LIMIT_REQUESTS_PER_MINUTE=100
EVALKIT_RATE_LIMIT_EVALUATE_PER_HOUR=20

# Frontend
EVALKIT_FRONTEND_URL=http://localhost:3003
EVALKIT_CORS_ORIGINS=http://localhost:3000,http://localhost:3003

# Frontend env (evalkit-ui/.env.local)
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# NEXT_PUBLIC_API_URL=http://localhost:8000
